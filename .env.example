# LLM provider (openai / anthropic / deepseek)
OPENBUSINESS_PROVIDER=openai

# Report language (zh / en)
OPENBUSINESS_OUTPUT_LANGUAGE=zh

# Terminal interface language (zh / en)
OPENBUSINESS_UI_LANGUAGE=zh

OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=1
DEEPSEEK_MAX_TOKENS=2048

# Optional evidence collection APIs
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
